{
  "entities": {
    "UserProfile": {
      "title": "UserProfile",
      "description": "Stores user's favorite transit routes and stations.",
      "type": "object",
      "properties": {
        "kmbFavs": {
          "type": "array",
          "description": "List of favorite KMB routes.",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "route": { "type": "string" },
              "bound": { "type": "string" },
              "orig_tc": { "type": "string" },
              "dest_tc": { "type": "string" },
              "stopId": { "type": "string" },
              "stopName": { "type": "string" }
            }
          }
        },
        "ctbFavs": {
          "type": "array",
          "description": "List of favorite CTB routes.",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "route": { "type": "string" },
              "bound": { "type": "string" },
              "orig_tc": { "type": "string" },
              "dest_tc": { "type": "string" },
              "stopId": { "type": "string" },
              "stopName": { "type": "string" }
            }
          }
        },
        "mtrFavs": {
          "type": "array",
          "description": "List of favorite MTR stations.",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "line": { "type": "string" },
              "station": { "type": "string" },
              "lineName": { "type": "string" },
              "stationName": { "type": "string" },
              "color": { "type": "string" }
            }
          }
        }
      }
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": {
        "$ref": "#/entities/UserProfile"
      },
      "description": "User profile document containing favorites."
    }
  }
}
